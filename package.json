{
  "name": "@optimystic/optimystic",
  "version": "0.14.1",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "resolutions": {
    "@quereus/quereus": "portal:../quereus/packages/quereus",
    "p2p-fret": "portal:../Fret/packages/fret",
    "protons-runtime": "^6.0.0",
    "uint8arrays": "^6.1.1"
  },
  "scripts": {
    "clean": "yarn workspaces foreach -Ap --exclude '@optimystic/optimystic' run clean",
    "build": "yarn workspaces foreach -At --exclude '@optimystic/optimystic' run build",
    "lint": "eslint .",
    "test": "yarn workspaces foreach -At --exclude '@optimystic/optimystic' run test",
    "test:verbose": "yarn workspaces foreach -At --exclude '@optimystic/optimystic' run test:verbose",
    "bump": "bumpp --recursive",
    "release": "yarn bump && yarn pub",
    "pub": "yarn build && yarn workspaces foreach -Apt --no-private npm publish --access public",
    "upgrade:fret": "ncu -u --workspaces --filter 'p2p-fret'",
    "upgrade:quereus": "ncu -u --workspaces --filter '@quereus/*'"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.13.10",
    "@yarnpkg/types": "^4.0.1",
    "bumpp": "^10.4.0",
    "eslint": "^9.18.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  }
}
