{
  "name": "@optimystic/optimystic",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "resolutions": {
    "@quereus/quereus": "portal:../quereus/packages/quereus"
  },
  "scripts": {
    "clean": "yarn clean:db-core && yarn clean:db-p2p && yarn clean:db-p2p-storage-fs && yarn clean:db-p2p-storage-rn && yarn clean:quereus-crypto && yarn clean:quereus-optimystic && yarn clean:reference-peer && yarn clean:demo",
    "clean:db-core": "cd packages/db-core && yarn clean",
    "clean:db-p2p": "cd packages/db-p2p && yarn clean",
    "clean:db-p2p-storage-fs": "cd packages/db-p2p-storage-fs && yarn clean",
    "clean:db-p2p-storage-rn": "cd packages/db-p2p-storage-rn && yarn clean",
    "clean:quereus-crypto": "cd packages/quereus-plugin-crypto && yarn clean",
    "clean:quereus-optimystic": "cd packages/quereus-plugin-optimystic && yarn clean",
    "clean:reference-peer": "cd packages/reference-peer && yarn clean",
    "clean:demo": "cd packages/demo && yarn clean",
    "bump": "bumpp --recursive --no-commit",
    "build": "yarn build:db-core && yarn build:db-p2p && yarn build:db-p2p-storage-fs && yarn build:db-p2p-storage-rn && yarn build:quereus-crypto && yarn build:quereus-optimystic && yarn build:reference-peer && yarn build:demo",
    "build:db-core": "cd packages/db-core && yarn build",
    "build:db-p2p": "cd packages/db-p2p && yarn build",
    "build:db-p2p-storage-fs": "cd packages/db-p2p-storage-fs && yarn build",
    "build:db-p2p-storage-rn": "cd packages/db-p2p-storage-rn && yarn build",
    "build:quereus-crypto": "cd packages/quereus-plugin-crypto && yarn build",
    "build:quereus-optimystic": "cd packages/quereus-plugin-optimystic && yarn build",
    "build:reference-peer": "cd packages/reference-peer && yarn build",
    "build:demo": "cd packages/demo && yarn build",
    "lint": "echo 'Lint not configured for all packages'",
    "test": "yarn test:db-core && yarn test:db-p2p && yarn test:quereus-crypto && yarn test:quereus-optimystic && yarn test:reference-peer && yarn test:demo",
    "test:db-core": "cd packages/db-core && yarn test",
    "test:db-p2p": "cd packages/db-p2p && yarn test",
    "test:quereus-crypto": "cd packages/quereus-plugin-crypto && yarn test",
    "test:quereus-optimystic": "cd packages/quereus-plugin-optimystic && yarn test",
    "test:reference-peer": "cd packages/reference-peer && yarn test",
    "test:demo": "cd packages/demo && yarn test",
    "pub": "yarn pub:db-core && yarn pub:db-p2p && yarn pub:db-p2p-storage-fs && yarn pub:db-p2p-storage-rn && yarn pub:quereus-crypto && yarn pub:quereus-optimystic && yarn pub:reference-peer",
    "pub:db-core": "node scripts/publish-package.js db-core",
    "pub:db-p2p": "node scripts/publish-package.js db-p2p",
    "pub:db-p2p-storage-fs": "node scripts/publish-package.js db-p2p-storage-fs",
    "pub:db-p2p-storage-rn": "node scripts/publish-package.js db-p2p-storage-rn",
    "pub:quereus-crypto": "node scripts/publish-package.js quereus-plugin-crypto",
    "pub:quereus-optimystic": "node scripts/publish-package.js quereus-plugin-optimystic",
    "pub:reference-peer": "node scripts/publish-package.js reference-peer",
    "upgrade:fret": "ncu -u --workspaces --filter 'p2p-fret'",
    "upgrade:quereus": "ncu -u --workspaces --filter '@quereus/*'"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "bumpp": "^10.4.0",
    "prettier": "^3.6.2"
  }
}
