{
  "name": "@optimystic/demo",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "description": "Hello world demo app exercising the full Optimystic stack",
  "main": "dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc",
    "start": "node --import ./register.mjs src/run.ts",
    "test": "node --import ./register.mjs node_modules/mocha/bin/mocha.js \"test/**/*.spec.ts\" --colors --reporter min"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.10",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@optimystic/db-core": "workspace:^"
  }
}
