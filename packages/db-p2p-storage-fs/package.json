{
	"name": "@optimystic/db-p2p-storage-fs",
	"version": "0.16.2",
	"type": "module",
	"description": "Node.js filesystem storage backend for @optimystic/db-p2p",
	"main": "dist/src/index.js",
	"types": "./dist/src/index.d.ts",
	"files": [
		"src",
		"dist",
		"!dist/test",
		"!**/*.tsbuildinfo"
	],
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.js"
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/gotchoices/optimystic.git",
		"directory": "packages/db-p2p-storage-fs"
	},
	"author": "Got Choices Foundation",
	"license": "MIT",
	"keywords": [
		"optimystic",
		"database",
		"p2p",
		"storage",
		"filesystem",
		"node"
	],
	"scripts": {
		"clean": "rimraf dist",
		"build": "tsc",
		"test": "node --import ./register.mjs node_modules/mocha/bin/mocha.js \"test/**/*.spec.ts\" --colors --reporter min",
		"test:verbose": "node --import ./register.mjs node_modules/mocha/bin/mocha.js \"test/**/*.spec.ts\" --colors --reporter spec"
	},
	"devDependencies": {
		"@types/debug": "^4.1.12",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.1.0",
		"mocha": "^11.7.5",
		"rimraf": "^6.1.2",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@optimystic/db-core": "workspace:^",
		"@optimystic/db-p2p": "workspace:^",
		"debug": "^4.4.3"
	}
}
