{
  "name": "@optimystic/vinz",
  "version": "0.0.1",
  "type": "module",
  "description": "Vinz Clortho - Threshold cryptography for Optimystic",
  "main": "dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "src",
    "dist",
    "!dist/test",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gotchoices/optimystic.git",
    "directory": "packages/vinz"
  },
  "author": "Got Choices Foundation",
  "license": "MIT",
  "keywords": [
    "optimystic",
    "threshold-cryptography",
    "cryptography",
    "crypto",
    "secp256k1",
    "multiformats"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc",
    "test": "node --import ./register.mjs node_modules/mocha/bin/mocha.js \"test/**/*.spec.ts\" --colors",
    "prove": "node --loader ts-node/esm test/test.ts"
  },
  "devDependencies": {
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@noble/secp256k1": "^2.2.3",
    "multiformats": "^13.3.2",
    "uint8arrays": "^5.1.0"
  }
}
