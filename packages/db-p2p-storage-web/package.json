{
  "name": "@optimystic/db-p2p-storage-web",
  "version": "0.13.0",
  "type": "module",
  "description": "Browser IndexedDB storage backend for @optimystic/db-p2p",
  "main": "dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "src",
    "dist",
    "!dist/test",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gotchoices/optimystic.git",
    "directory": "packages/db-p2p-storage-web"
  },
  "author": "Got Choices Foundation",
  "license": "MIT",
  "keywords": [
    "optimystic",
    "database",
    "p2p",
    "storage",
    "browser",
    "indexeddb"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc",
    "test": "node --import ./register.mjs node_modules/mocha/bin/mocha.js \"test/**/*.spec.ts\" --colors --reporter min",
    "test:verbose": "node --import ./register.mjs node_modules/mocha/bin/mocha.js \"test/**/*.spec.ts\" --colors --reporter spec"
  },
  "devDependencies": {
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/interface": "^3.1.0",
    "@libp2p/peer-id": "^6.0.4",
    "@types/chai": "^5.2.3",
    "@types/debug": "^4.1.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.1.0",
    "chai": "^6.2.2",
    "fake-indexeddb": "^6.2.4",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@optimystic/db-core": "workspace:^",
    "@optimystic/db-p2p": "workspace:^",
    "debug": "^4.4.3",
    "idb": "^8.0.3"
  },
  "peerDependencies": {
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/interface": "^3.1.0"
  }
}
